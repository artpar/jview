{"type":"createSurface","surfaceId":"main","title":"Window Events Demo","width":600,"height":400}
{"type":"on","surfaceId":"main","id":"resize","event":"window.resize","handler":{"dataPath":"/window/size"}}
{"type":"on","surfaceId":"main","id":"move","event":"window.move","handler":{"dataPath":"/window/position"}}
{"type":"on","surfaceId":"main","id":"focus","event":"window.becomeKey","handler":{"dataPath":"/window/focused","dataValue":true}}
{"type":"on","surfaceId":"main","id":"blur","event":"window.resignKey","handler":{"dataPath":"/window/focused","dataValue":false}}
{"type":"component","surfaceId":"main","componentId":"root","type":"Column","props":{"padding":20,"spacing":16}}
{"type":"component","surfaceId":"main","componentId":"title","type":"Text","props":{"content":"Window Events","style":"title","parentId":"root"}}
{"type":"component","surfaceId":"main","componentId":"info","type":"Text","props":{"content":"Resize or move the window to see events.","parentId":"root"}}
{"type":"component","surfaceId":"main","componentId":"size-label","type":"Text","props":{"content":{"$expr":"'Size: ' + str(get('/window/size/width', '?')) + ' × ' + str(get('/window/size/height', '?'))"},"parentId":"root"}}
{"type":"component","surfaceId":"main","componentId":"pos-label","type":"Text","props":{"content":{"$expr":"'Position: ' + str(get('/window/position/x', '?')) + ', ' + str(get('/window/position/y', '?'))"},"parentId":"root"}}
{"type":"component","surfaceId":"main","componentId":"focus-label","type":"Text","props":{"content":{"$expr":"get('/window/focused', false) ? 'Window: Focused' : 'Window: Not Focused'"},"parentId":"root"}}
